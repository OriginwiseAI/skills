{
  "name": "kpainter-openclaw",
  "displayName": "KPainter OpenClaw",
  "version": "0.1.3",
  "description": "OpenClaw plugin for KPainter explainer video, slides, image, and interactive lesson APIs. Latest image support now includes GPT-Image-2.",
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "README.md",
    "openclaw.plugin.json",
    "src/index.js"
  ],
  "keywords": [
    "openclaw",
    "clawhub",
    "kpainter",
    "explainer-video",
    "slides",
    "image",
    "interactive-lesson",
    "gpt-image-2"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.3.22"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./src/index.js"
    ],
    "compat": {
      "pluginApi": "^1.2.0"
    },
    "build": {
      "openclawVersion": "2026.3.22",
      "pluginSdkVersion": "2026.3.22"
    },
    "configSchema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "apiBaseUrl": {
          "type": "string",
          "default": "https://kpainter.ai/kp-app-api/v1",
          "description": "KPainter API base URL."
        },
        "apiKey": {
          "type": "string",
          "description": "KPainter API key from https://kpainter.ai/api-key."
        },
        "requestTimeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 120000,
          "default": 30000,
          "description": "Per-request timeout in milliseconds."
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OriginwiseAI/skills.git",
    "directory": "plugins/kpainter-openclaw"
  }
}
